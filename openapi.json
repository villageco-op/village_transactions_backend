{
  "openapi": "3.0.0",
  "info": {
    "version": "1.0.0",
    "title": "Marketplace API",
    "description": "API for Village Website & Marketplace"
  },
  "components": {
    "schemas": {},
    "parameters": {}
  },
  "paths": {
    "/api/users/me": {
      "get": {
        "operationId": "getCurrentUser",
        "description": "Fetch profile, settings, and active seller status.",
        "responses": {
          "200": {
            "description": "User Profile",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    }
                  },
                  "required": ["id"],
                  "additionalProperties": {
                    "nullable": true
                  }
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updateCurrentUser",
        "description": "Update profile (name, address, delivery range, etc.)",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "address": {
                    "type": "string"
                  },
                  "lat": {
                    "type": "number"
                  },
                  "lng": {
                    "type": "number"
                  },
                  "deliveryRangeMiles": {
                    "type": "number"
                  }
                },
                "required": ["name", "address", "lat", "lng", "deliveryRangeMiles"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated Profile",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    }
                  },
                  "required": ["success"]
                }
              }
            }
          }
        }
      }
    },
    "/api/users/fcm-token": {
      "post": {
        "operationId": "registerFcmToken",
        "description": "Store the user's Firebase Cloud Messaging token for push notifications.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "token": {
                    "type": "string"
                  },
                  "platform": {
                    "type": "string"
                  }
                },
                "required": ["token", "platform"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token stored",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    }
                  },
                  "required": ["success"]
                }
              }
            }
          }
        }
      }
    },
    "/api/users/me/schedule-rules": {
      "put": {
        "operationId": "updateScheduleRules",
        "description": "Seller defines their base availability.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "pickupWindows": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "day": {
                          "type": "string"
                        },
                        "start": {
                          "type": "string"
                        },
                        "end": {
                          "type": "string"
                        }
                      },
                      "required": ["day", "start", "end"]
                    }
                  }
                },
                "required": ["pickupWindows"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Schedule updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    }
                  },
                  "required": ["success"]
                }
              }
            }
          }
        }
      }
    },
    "/api/produce/map": {
      "get": {
        "operationId": "getProduceMap",
        "description": "See sellers on a map.",
        "parameters": [
          {
            "schema": {
              "type": "number",
              "nullable": true
            },
            "required": false,
            "name": "lat",
            "in": "query"
          },
          {
            "schema": {
              "type": "number",
              "nullable": true
            },
            "required": false,
            "name": "lng",
            "in": "query"
          },
          {
            "schema": {
              "type": "number",
              "nullable": true
            },
            "required": false,
            "name": "radiusMiles",
            "in": "query"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "produceType",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "enum": ["true", "false"]
            },
            "required": false,
            "name": "hasDelivery",
            "in": "query"
          },
          {
            "schema": {
              "type": "number",
              "nullable": true
            },
            "required": false,
            "name": "maxPrice",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "Map items",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "nullable": true
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/produce/list": {
      "get": {
        "operationId": "getProduceList",
        "description": "See list of produce/sellers.",
        "parameters": [
          {
            "schema": {
              "type": "number",
              "nullable": true
            },
            "required": false,
            "name": "lat",
            "in": "query"
          },
          {
            "schema": {
              "type": "number",
              "nullable": true
            },
            "required": false,
            "name": "lng",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "enum": ["distance", "price"]
            },
            "required": false,
            "name": "sortBy",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "enum": ["true", "false"]
            },
            "required": false,
            "name": "hasDelivery",
            "in": "query"
          },
          {
            "schema": {
              "type": "number",
              "nullable": true,
              "default": 20
            },
            "required": false,
            "name": "limit",
            "in": "query"
          },
          {
            "schema": {
              "type": "number",
              "nullable": true,
              "default": 0
            },
            "required": false,
            "name": "offset",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "List of produce",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "nullable": true
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/produce": {
      "post": {
        "operationId": "createProduce",
        "description": "Create a new listing.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": {
                    "type": "string"
                  },
                  "pricePerOz": {
                    "type": "number"
                  },
                  "totalOzInventory": {
                    "type": "number"
                  },
                  "harvestFrequencyDays": {
                    "type": "number"
                  },
                  "seasonStart": {
                    "type": "string"
                  },
                  "seasonEnd": {
                    "type": "string"
                  },
                  "images": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "isSubscribable": {
                    "type": "boolean"
                  }
                },
                "required": [
                  "title",
                  "pricePerOz",
                  "totalOzInventory",
                  "harvestFrequencyDays",
                  "seasonStart",
                  "seasonEnd",
                  "images",
                  "isSubscribable"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Listing created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    }
                  },
                  "required": ["id"]
                }
              }
            }
          }
        }
      }
    },
    "/api/produce/{id}": {
      "put": {
        "operationId": "updateProduce",
        "description": "Update a listing or pause it.",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "status": {
                    "type": "string",
                    "enum": ["active", "paused"]
                  },
                  "totalOzInventory": {
                    "type": "number"
                  }
                },
                "required": ["status", "totalOzInventory"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Listing updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    }
                  },
                  "required": ["success"]
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteProduce",
        "description": "Remove a listing (soft delete).",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Listing deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    }
                  },
                  "required": ["success"]
                }
              }
            }
          }
        }
      }
    },
    "/api/cart": {
      "get": {
        "operationId": "getCart",
        "description": "Fetch user's active cart, grouped by seller. Drops expired reservations automatically.",
        "responses": {
          "200": {
            "description": "Cart Object",
            "content": {
              "application/json": {
                "schema": {
                  "nullable": true
                }
              }
            }
          }
        }
      }
    },
    "/api/cart/add": {
      "post": {
        "operationId": "addToCart",
        "description": "Add item to cart and create a soft reservation.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "productId": {
                    "type": "string"
                  },
                  "quantityOz": {
                    "type": "number"
                  },
                  "isSubscription": {
                    "type": "boolean"
                  }
                },
                "required": ["productId", "quantityOz", "isSubscription"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Added to cart",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    }
                  },
                  "required": ["success"]
                }
              }
            }
          }
        }
      }
    },
    "/api/cart/remove/{reservationId}": {
      "delete": {
        "operationId": "removeFromCart",
        "description": "Explicitly remove an item and release the reservation early.",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "reservationId",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Removed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    }
                  },
                  "required": ["success"]
                }
              }
            }
          }
        }
      }
    },
    "/api/checkout/stripe/session": {
      "post": {
        "operationId": "createStripeSession",
        "description": "Create a Stripe Checkout session for a specific seller.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "sellerId": {
                    "type": "string"
                  },
                  "fulfillmentType": {
                    "type": "string",
                    "enum": ["pickup", "delivery"]
                  },
                  "scheduledTime": {
                    "type": "string",
                    "format": "date-time"
                  }
                },
                "required": ["sellerId", "fulfillmentType", "scheduledTime"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Session created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "url": {
                      "type": "string"
                    }
                  },
                  "required": ["url"]
                }
              }
            }
          }
        }
      }
    },
    "/api/checkout/snap/initiate": {
      "post": {
        "operationId": "initiateSnapCheckout",
        "description": "Alternate checkout route for USDA EBT/SNAP.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "sellerId": {
                    "type": "string"
                  },
                  "fulfillmentType": {
                    "type": "string",
                    "enum": ["pickup"]
                  }
                },
                "required": ["sellerId", "fulfillmentType"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "SNAP Init",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    }
                  },
                  "required": ["success"]
                }
              }
            }
          }
        }
      }
    },
    "/api/stripe/webhook": {
      "post": {
        "operationId": "handleStripeWebhook",
        "description": "Secure server-to-server listener for Stripe events.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "nullable": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Received",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "received": {
                      "type": "boolean"
                    }
                  },
                  "required": ["received"]
                }
              }
            }
          }
        }
      }
    },
    "/api/stripe/connect/onboard": {
      "post": {
        "operationId": "generateStripeOnboardingLink",
        "description": "Generate onboarding link for sellers to link their bank accounts.",
        "responses": {
          "200": {
            "description": "Link created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "url": {
                      "type": "string"
                    }
                  },
                  "required": ["url"]
                }
              }
            }
          }
        }
      }
    },
    "/api/orders": {
      "get": {
        "operationId": "getOrders",
        "description": "Get historical or active orders.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "enum": ["buyer", "seller"]
            },
            "required": true,
            "name": "role",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "enum": ["active", "completed", "canceled"]
            },
            "required": true,
            "name": "status",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "Orders list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "nullable": true
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/orders/{id}/schedule": {
      "put": {
        "operationId": "rescheduleOrder",
        "description": "Request a change to pickup/delivery time.",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "newTime": {
                    "type": "string",
                    "format": "date-time"
                  }
                },
                "required": ["newTime"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Rescheduled",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    }
                  },
                  "required": ["success"]
                }
              }
            }
          }
        }
      }
    },
    "/api/orders/{id}/cancel": {
      "put": {
        "operationId": "cancelOrder",
        "description": "Cancel a one-time order.",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "reason": {
                    "type": "string"
                  }
                },
                "required": ["reason"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Canceled",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    }
                  },
                  "required": ["success"]
                }
              }
            }
          }
        }
      }
    },
    "/api/subscriptions/{id}/status": {
      "put": {
        "operationId": "updateSubscriptionStatus",
        "description": "Manage recurring scheduled purchases.",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "status": {
                    "type": "string",
                    "enum": ["paused", "active", "canceled"]
                  }
                },
                "required": ["status"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Status updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    }
                  },
                  "required": ["success"]
                }
              }
            }
          }
        }
      }
    },
    "/api/availability/{sellerId}": {
      "get": {
        "operationId": "getAvailability",
        "description": "Fetch available pickup/delivery slots for a seller.",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "sellerId",
            "in": "path"
          },
          {
            "schema": {
              "type": "string",
              "enum": ["pickup", "delivery"]
            },
            "required": true,
            "name": "type",
            "in": "query"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "date",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "Available slots",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/conversations": {
      "get": {
        "operationId": "getConversations",
        "description": "List all active chat threads for the user.",
        "responses": {
          "200": {
            "description": "Conversations list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "nullable": true
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/messages": {
      "get": {
        "operationId": "getMessages",
        "description": "Short-polling endpoint for the active chat screen.",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "conversationId",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "required": true,
            "name": "since",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "Messages list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "nullable": true
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "sendMessage",
        "description": "Send a message.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "conversationId": {
                    "type": "string"
                  },
                  "text": {
                    "type": "string"
                  }
                },
                "required": ["conversationId", "text"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message sent",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    }
                  },
                  "required": ["success"]
                }
              }
            }
          }
        }
      }
    },
    "/api/seller/customers": {
      "get": {
        "operationId": "getSellerCustomers",
        "description": "View everyone who has bought before.",
        "responses": {
          "200": {
            "description": "Customers list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "nullable": true
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/seller/analytics": {
      "get": {
        "operationId": "getSellerAnalytics",
        "description": "View past sales totals and metrics.",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "timeframe",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "Analytics object",
            "content": {
              "application/json": {
                "schema": {
                  "nullable": true
                }
              }
            }
          }
        }
      }
    },
    "/api/cron/release-carts": {
      "post": {
        "operationId": "cronReleaseCarts",
        "description": "Cleanup routine triggered by Vercel Cron every 5 minutes.",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "authorization",
            "in": "header"
          }
        ],
